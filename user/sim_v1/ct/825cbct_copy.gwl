# Detector positioning
DetModuleNum         3            # Number of detector modules 
DetectorModuleRadius -1           # Curved detector radius (-1 for flat panel)
DetDistance        490           # Detector-to-world center distance (DSD - DSO) (mm)

DetOffsetX          0            # Detector offset in X direction (mm)
DetOffsetY          0            # Detector offset in Y direction (mm)
DetYaw              0            # Detector yaw angle (degrees)
DetPitch            0            # Detector pitch angle (degrees)
DetRoll             0            # Detector roll angle (degrees)
DetFilter1           1            # Add filter: 1 for yes  0 for no
DetFilter2           1            # Add filter: 1 for yes  0 for no
DetFilter3           1            # Add filter: 1 for yes  0 for no

# Detector filtration layers
DetFilter1Material   Al          # Detector filter 1 material
DetFilter1SizeX     100          # Detector filter 1 size in X direction (mm)
DetFilter1SizeY     100          # Detector filter 1 size in Y direction (mm)
DetFilter1Thick      0.1         # Detector filter 1 thickness (mm)
DetFilter1Pos        0.0         # Detector filter 1 position from surface (mm)
DetFilter1OffsetX    0           # Detector filter 1 X offset (mm)
DetFilter1OffsetY    0           # Detector filter 1 Y offset (mm)

DetFilter2Material   Al          # Detector filter 2 material
DetFilter2SizeX     100          # Detector filter 2 size in X direction (mm)
DetFilter2SizeY     100          # Detector filter 2 size in Y direction (mm)
DetFilter2Thick      0.1         # Detector filter 2 thickness (mm)
DetFilter2Pos        0.0         # Detector filter 2 position from surface (mm)
DetFilter2OffsetX    0           # Detector filter 2 X offset (mm)
DetFilter2OffsetY    0           # Detector filter 2 Y offset (mm)

# Phantom configuration
PhantomScale         3           # Scaling factor for phantom size
PhantomOffsetX       1           # Phantom offset in X direction (mm)
PhantomOffsetY       1           # Phantom offset in Y direction (mm)
PhantomOffsetZ       0           # Phantom offset in Z direction (mm)
PhantomRotX          0           # Phantom rotation in X axis (degrees)
PhantomRotY          0           # Phantom rotation in Y axis (degrees)
PhantomRotZ          0           # Phantom rotation in Z axis (degrees)

# Tube filtration (pre-filter)
TubeFilter1Material  Al          # Tube filter 1 material
TubeFilter1SizeX    100          # Tube filter 1 size in X direction (mm)
TubeFilter1SizeY    100          # Tube filter 1 size in Y direction (mm)
TubeFilter1Thick     0.1         # Tube filter 1 thickness (mm)
TubeFilter1Pos       0.0         # Tube filter 1 position from surface (mm)
TubeFilter1OffsetX   0           # Tube filter 1 X offset (mm)
TubeFilter1OffsetY   0           # Tube filter 1 Y offset (mm)

TubeFilter2Material  Al          # Tube filter 2 material
TubeFilter2SizeX    100          # Tube filter 2 size in X direction (mm)
TubeFilter2SizeY    100          # Tube filter 2 size in Y direction (mm)
TubeFilter2Thick     0.1         # Tube filter 2 thickness (mm)
TubeFilter2Pos       0.0         # Tube filter 2 position from surface (mm)
TubeFilter2OffsetX   0           # Tube filter 2 X offset (mm)
TubeFilter2OffsetY   0           # Tube filter 2 Y offset (mm)

# X-ray tube parameters
FanAngle            60           # Fan angle (degrees)
ConeAngle           10           # Cone angle in Z (degrees)
TubeDistance       595           # Tube distance from rotation center (mm)
TubeYaw              0           # Tube yaw angle (degrees)
TubePitch            0           # Tube pitch angle (degrees)
TubeRoll             0           # Tube roll angle (degrees)

# Scan protocol
TotalViews         720           # Total exposure views
CircleViews        360           # Views per rotation circle
StartAngle           0           # Starting angle of exposure
StartIndex         100           # Starting index for simulation
HelicalPitch        0.5          # CT helical pitch
BedDirection         0           # Phantom bed direction (0 or 1)
PhotonCount   10000000           # Number of photons per view

# Physics Processes
PhotoEffect           1           # Enable Photoelectric Effect
ComptonScatter        1           # Enable Compton Scattering
RayleighScatter       1           # Enable Rayleigh Scattering
GammaConvert          1           # Enable Gamma Conversion (e⁺/e⁻ pair)
XrayReflect           1           # Enable X-ray Reflection (optical simulation)
# Geometry
DetCountX           768          # Number of detector units along X
DetCountY           768          # Number of detector units along Y
DetUnitSizeX        0.2          # Detector unit size in X (mm)
DetUnitSizeY        0.2          # Detector unit size in Y (mm)
DetUnitThickness    0.6          # Detector unit thickness (mm)
DetectorRadius      -1           # Curved detector radius (-1 for flat panel)

# Materials
DetectorMaterial     GOS         # Detector material
#PCCT                 0           # Is it a photon counting detector: 0 for No, 1 for Yes
#PCCTTh1              20          # Photon counting detector energy threshold 1    
#PCCTTh1              60          # Photon counting detector energy threshold 2    
# IO Paths
DetectorPath   /home/vgate/software_gy/share/CTISS/user/test1            # Detector path
SpectrumPath   /home/vgate/software_gy/share/CTISS/user/test2            # X-ray spectrum path
PhantomPath    /home/vgate/software_gy/share/CTISS/user/test3            # Phantom data path
PhantomScript  /home/vgate/software_gy/share/CTISS/user/test            # Phantom script path
OutputPath     /home/vgate/software_gy/share/CTISS/user/test4            # Simulation output path
OutputFilename        result       # Filename of simulation output
